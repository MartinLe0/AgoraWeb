{% extends 'base.html.twig' %}

{% block title %}CatTournoi{% endblock %}

{% block body %}
    <h1>CatTournoi</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ cat_tournoi.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ cat_tournoi.nom }}</td>
            </tr>
            <tr>
                <th>Tournois associés</th>
                <td>
                    {% if cat_tournoi.tournois is empty %}
                        Aucun tournoi
                    {% else %}
                        <ul>
                        {% for tournoi in cat_tournoi.tournois %}
                            <li>{{ tournoi.nom }} ({{ tournoi.dateDebut|date('d/m/Y') }})</li>
                        {% endfor %}
                        </ul>
                    {% endif %}
                </td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_cat_tournoi_index') }}">back to list</a>

    <a href="{{ path('app_cat_tournoi_edit', {'id': cat_tournoi.id}) }}">edit</a>

    {{ include('cat_tournoi/_delete_form.html.twig') }}
{% endblock %}
