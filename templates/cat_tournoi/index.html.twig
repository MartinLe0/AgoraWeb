{% extends 'base.html.twig' %}

{% block title %}CatTournoi index{% endblock %}

{% block body %}
    <div class="col-sm-8">
        <section class="panel">
            <div class="chat-room-head">
                <h3><i class="fa fa-angle-right"></i> Gérer les catégories de tournois</h3>
            </div>
            <div class="panel-body">
                <table class="table table-striped table-advance table-hover">
                    <thead>
                        <tr class="tableau-entete">
                            <th><i class="fa fa-bullhorn"></i> Id</th>
                            <th><i class="fa fa-bookmark"></i> Libelle</th>
                            <th><i class="fa fa-trophy"></i> Tournois</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for cat_tournoi in cat_tournois %}
                        <tr>
                            <td>{{ cat_tournoi.id }}</td>
                            <td>{{ cat_tournoi.nom }}</td>
                            <td>
                                {% if cat_tournoi.tournois is empty %}
                                    Aucun tournoi
                                {% else %}
                                    {% for tournoi in cat_tournoi.tournois %}
                                        <span class="badge bg-theme">{{ tournoi.nom }}</span>
                                    {% endfor %}
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('app_cat_tournoi_show', {'id': cat_tournoi.id}) }}"><button class="btn btn-primary btn-xs"><i class="fa fa-tasks"></i></button></a>
                                <a href="{{ path('app_cat_tournoi_edit', {'id': cat_tournoi.id}) }}"><button class="btn btn-primary btn-xs"><i class="fa fa-pencil"></i></button></a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3">Aucune catégorie enregistrée</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>

                <a href="{{ path('app_cat_tournoi_new') }}"><button class="btn btn-primary btn-xs"><i class="fa fa-plus"></i></button></a>
            </div>
        </section>
    </div>
{% endblock %}
