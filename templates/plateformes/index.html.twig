{% extends 'base.html.twig' %}

{% block title %}Plateformes index{% endblock %}

{% block body %}
    <div class="col-sm-8">
    <section class="panel">
    <div class="chat-room-head">
    <h3><i class="fa fa-angle-right"></i> Gérer les plateformes</h3>
    </div>
    <div class="panel-body">
    <table class="table" table-striped table-advance table-hover">
            <thead>
            <tr class="tableau-entete">
            <th>Identifiant</th>
            <th>Libellé</th>
            <th>Jeux</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        {% for plateforme in plateformes %}
            <tr>
                <td>{{ plateforme.id }}</td>
                <td>{{ plateforme.libPlateforme }}</td>
                <td>
                    {% if plateforme.jeux is empty %}
                        Aucun jeu
                    {% else %}
                        {% for jeu in plateforme.jeux %}
                            <span class="badge bg-theme">{{ jeu.nom }}</span>
                        {% endfor %}
                    {% endif %}
                </td>
                <td>
                    <a href="{{path('app_plateformes_show',{'id': plateforme.id})}}"><button class="btn btn-primary btn-xs"><i class="fa fa-tasks"></i></button></a>
                    <a href="{{path('app_plateformes_edit',{'id': plateforme.id})}}"><button class="btn btn-primary btn-xs"><i class="fa fa-pencil"></i></button></a>
                    {{ include('plateformes/_delete_form.html.twig') }}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">aucune plateforme enregistrée en base de données</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_plateformes_new') }}"><button class="btn btn-primary btn-xs"><i class="fa fa-plus"></i></button></a>
    </div>
    </section>
    </div>
{% endblock %}
