{% extends 'base.html.twig' %}

{% block title %}Éditer: {{ jeu.nom }}{% endblock %}

{% block central %}
<div class="col-sm-12">
    <section class="panel">
        <div class="chat-room-head">
            <h3><i class="fa fa-angle-right"></i> Éditer le jeu vidéo: {{ jeu.nom }}</h3>
        </div>
        <div class="panel-body">
            {{ include('jeuvideo/_form.html.twig', {'form': form, 'button_label': 'Mettre à jour'}) }}

            <div class="mt-3">
                <a href="{{ path('app_jeuvideo_show', {'refJeu': jeu.refJeu}) }}" class="btn btn-info btn-xs" title="Voir">
                    <i class="fa fa-eye"></i> Afficher
                </a>
                <a href="{{ path('app_jeuvideo_index') }}" class="btn btn-secondary btn-xs" title="Retour">
                    <i class="fa fa-arrow-left"></i> Retour à la liste
                </a>
            </div>

            {{ include('jeuvideo/_delete_form.html.twig') }}
        </div>
    </section>
</div>
{% endblock %}
