{% extends 'base.html.twig' %}

{% block title %}{{ jeu.nom }}{% endblock %}

{% block central %}
<div class="col-sm-12">
    <section class="panel">
        <div class="chat-room-head">
            <h3><i class="fa fa-angle-right"></i> {{ jeu.nom }}</h3>
        </div>
        <div class="panel-body">
            <table class="table table-striped table-advance table-hover">
                <tbody>
                    <tr>
                        <th>Référence</th>
                        <td>{{ jeu.refJeu }}</td>
                    </tr>
                    <tr>
                        <th>Nom</th>
                        <td>{{ jeu.nom }}</td>
                    </tr>
                    <tr>
                        <th>Prix</th>
                        <td>{{ jeu.prix|number_format(2, ',', ' ') }} €</td>
                    </tr>
                    <tr>
                        <th>Date de parution</th>
                        <td>{{ jeu.dateParution|date('d/m/Y') }}</td>
                    </tr>
                    <tr>
                        <th>Genre</th>
                        <td>{{ jeu.genre.libGenre ?? 'N/A' }}</td>
                    </tr>
                    <tr>
                        <th>PEGI</th>
                        <td>{{ jeu.pegi.descPegi ?? 'N/A' }}</td>
                    </tr>
                    <tr>
                        <th>Plateforme</th>
                        <td>{{ jeu.plateforme.libPlateforme ?? 'N/A' }}</td>
                    </tr>
                    <tr>
                        <th>Marque</th>
                        <td>{{ jeu.marque.nomMarque ?? 'N/A' }}</td>
                    </tr>
                </tbody>
            </table>

            <div class="mt-3">
                <a href="{{ path('app_jeuvideo_edit', {'refJeu': jeu.refJeu}) }}" class="btn btn-primary btn-xs" title="Éditer">
                    <i class="fa fa-pencil"></i> Éditer
                </a>
                <a href="{{ path('app_jeuvideo_index') }}" class="btn btn-secondary btn-xs" title="Retour">
                    <i class="fa fa-arrow-left"></i> Retour à la liste
                </a>
            </div>

            {{ include('jeuvideo/_delete_form.html.twig') }}
        </div>
    </section>
</div>
{% endblock %}
