{% extends 'base.html.twig' %}

{% block title %}Liste des jeux vidéo{% endblock %}

{% block central %}
<div class="col-sm-12">
    <section class="panel">
        <div class="chat-room-head">
            <h3><i class="fa fa-angle-right"></i> Gérer les jeux vidéo</h3>
        </div>
        <div class="panel-body">
            <a href="{{ path('app_jeuvideo_new') }}" class="btn btn-success btn-xs mb-3">
                <i class="fa fa-plus"></i> Ajouter un nouveau jeu
            </a>

            {% if jeux is empty %}
                <p class="alert alert-info">Aucun jeu vidéo trouvé.</p>
            {% else %}
                <table class="table table-striped table-advance table-hover">
                    <thead>
                        <tr class="tableau-entete">
                            <th><i class="fa fa-bookmark"></i> Référence</th>
                            <th><i class="fa fa-bookmark"></i> Nom</th>
                            <th><i class="fa fa-bookmark"></i> Prix</th>
                            <th><i class="fa fa-bookmark"></i> Date de parution</th>
                            <th><i class="fa fa-bookmark"></i> Genre</th>
                            <th><i class="fa fa-bookmark"></i> PEGI</th>
                            <th><i class="fa fa-bookmark"></i> Plateforme</th>
                            <th><i class="fa fa-bookmark"></i> Marque</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for jeu in jeux %}
                            <tr>
                                <td>{{ jeu.refJeu }}</td>
                                <td>{{ jeu.nom }}</td>
                                <td>{{ jeu.prix|number_format(2, ',', ' ') }} €</td>
                                <td>{{ jeu.dateParution|date('d/m/Y') }}</td>
                                <td>{{ jeu.genre.libGenre ?? 'N/A' }}</td>
                                <td>{{ jeu.pegi.descPegi ?? 'N/A' }}</td>
                                <td>{{ jeu.plateforme.libPlateforme ?? 'N/A' }}</td>
                                <td>{{ jeu.marque.nomMarque ?? 'N/A' }}</td>
                                <td>
                                    <a href="{{ path('app_jeuvideo_show', {'refJeu': jeu.refJeu}) }}" class="btn btn-info btn-xs" title="Voir">
                                        <i class="fa fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_jeuvideo_edit', {'refJeu': jeu.refJeu}) }}" class="btn btn-primary btn-xs" title="Éditer">
                                        <i class="fa fa-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}
