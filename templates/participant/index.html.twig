{% extends 'base.html.twig' %}

{% block title %}Participant index{% endblock %}

{% block body %}
    <div class="col-sm-12">
    <section class="panel">
    <div class="chat-room-head">
    <h3><i class="fa fa-angle-right"></i> Gérer les participants</h3>
    </div>
    <div class="panel-body">
    <table class="table table-striped table-advance table-hover">
            <thead>
            <tr class="tableau-entete">
            <th><i class="fa fa-bullhorn"></i> Id</th>
            <th><i class="fa fa-user"></i> Prenom</th>
            <th><i class="fa fa-user"></i> Nom</th>
            <th><i class="fa fa-phone"></i> Telephone</th>
            <th><i class="fa fa-envelope"></i> Email</th>
            <th><i class="fa fa-trophy"></i> Tournois</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        {% for participant in participants %}
            <tr>
                <td>{{ participant.id }}</td>
                <td>{{ participant.prenom }}</td>
                <td>{{ participant.nom }}</td>
                <td>{{ participant.telephone }}</td>
                <td>{{ participant.email }}</td>
                <td>
                    {% if participant.tournois is empty %}
                        Aucun tournoi
                    {% else %}
                        {% for tournoi in participant.tournois %}
                            <span class="badge bg-theme">{{ tournoi.nom }}</span>
                        {% endfor %}
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_participant_show', {'id': participant.id}) }}"><button class="btn btn-primary btn-xs"><i class="fa fa-tasks"></i></button></a>
                    <a href="{{ path('app_participant_edit', {'id': participant.id}) }}"><button class="btn btn-primary btn-xs"><i class="fa fa-pencil"></i></button></a>
                    {{ include('participant/_delete_form.html.twig') }}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">Aucun participant enregistré</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_participant_new') }}"><button class="btn btn-primary btn-xs"><i class="fa fa-plus"></i></button></a>
    </div>
    </section>
    </div>
{% endblock %}
